{
  "name": "mebius-code",
  "version": "0.1.4",
  "private": false,
  "description": "Terminal client for Mebius Code.",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlbertTeslaWizard/Mebius-Code.git",
    "directory": "tui"
  },
  "bin": {
    "mebius": "bin/mebius.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "start": "bun --preload @opentui/solid/preload src/cli.tsx",
    "build:native": "bun ./scripts/build-native.ts",
    "stage:npm": "node ./scripts/stage-npm-packages.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "optionalDependencies": {
    "@albert_tesla/mebius-code-darwin-arm64": "0.1.4",
    "@albert_tesla/mebius-code-darwin-x64": "0.1.4",
    "@albert_tesla/mebius-code-linux-x64": "0.1.4",
    "@albert_tesla/mebius-code-win32-x64": "0.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@opentui/core": "0.3.4",
    "@opentui/solid": "0.3.4",
    "@types/node": "^22.10.2",
    "@unified-latex/unified-latex-util-parse": "1.8.4",
    "solid-js": "1.9.12",
    "typescript": "^5.7.2"
  }
}
