NODE_ENV=development
PORT=3000
API_PREFIX=api
MEBIUS_CODE_SERVER_MODE=development
MEBIUS_CODE_LOCAL_WORKSPACES_ENABLED=false

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=mebius
DATABASE_PASSWORD=mebius_dev_password
DATABASE_NAME=mebius_code
DATABASE_SYNCHRONIZE=true

JWT_SECRET=replace-with-a-long-random-development-secret
JWT_EXPIRES_IN=7d
ADMIN_INVITE_CODE=replace-with-optional-admin-code

MAIL_ENABLED=false
MAIL_APP_NAME=Mebius Code
MAIL_FROM="Mebius Code <no-reply@example.com>"
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace-with-brevo-smtp-login
SMTP_PASS=replace-with-brevo-smtp-key

MEBIUS_CODE_MASTER_KEY=replace-with-a-32-byte-or-longer-secret
MEBIUS_CODE_WORKSPACE_ROOT=./workspaces
MEBIUS_CODE_COMMAND_ALLOWLIST=git status,git diff,git log,npm test,npm run test,npm run build,npm run lint,node --version,npm --version

WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=exa
EXA_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_MS=10000
WEB_SEARCH_CONTEXT_MAX_CHARACTERS=10000
WEB_SEARCH_ALLOWED_DOMAINS=
WEB_SEARCH_BLOCKED_DOMAINS=
