@startuml
left to right direction
actor "普通开发者" as Dev
actor "管理员" as Admin

rectangle "Mebius Code" {
  usecase "注册/登录" as UCAuth
  usecase "维护模型配置" as UCModel
  usecase "通过 /connect 连接模型" as UCConnect
  usecase "创建/删除项目" as UCProject
  usecase "导入 Git 仓库" as UCGitImport
  usecase "导入 ZIP 归档" as UCArchive
  usecase "浏览和编辑文件" as UCFiles
  usecase "管理 Git 暂存/提交/推送" as UCGit
  usecase "创建 Agent 会话" as UCSession
  usecase "生成并批准计划" as UCPlan
  usecase "与 Agent 对话" as UCChat
  usecase "审批补丁或命令" as UCApprove
  usecase "回滚补丁" as UCRevert
  usecase "查看命令运行记录" as UCRuns
  usecase "管理命令策略" as UCCommandPolicy
  usecase "查看审计日志" as UCAudit
}

Dev --> UCAuth
Dev --> UCModel
Dev --> UCConnect
Dev --> UCProject
Dev --> UCGitImport
Dev --> UCArchive
Dev --> UCFiles
Dev --> UCGit
Dev --> UCSession
Dev --> UCPlan
Dev --> UCChat
Dev --> UCApprove
Dev --> UCRevert
Dev --> UCRuns
Dev --> UCAudit

Admin --> UCCommandPolicy
Admin --> UCAudit
Admin --> UCApprove
@enduml
